{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'ROOT=$(git rev-parse --show-toplevel); \"$ROOT/.codex/hooks/session-start.sh\"'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'ROOT=$(git rev-parse --show-toplevel); \"$ROOT/.codex/hooks/stop.sh\"'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
